    "url": "https://github.com/jneander/jneander/issues"
  },
  "homepage": "https://github.com/jneander/jneander",
  "dependencies": {
    "qs": "^6.5.2",
    "url-pattern": "^1.0.3"
  },
  "devDependencies": {
    "@jneander/dev-lint": "^1.0.0",
    "@jneander/dev-tools": "^0.0.13"
  }
