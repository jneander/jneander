  "description": "Routing by domain concepts instead of URLs",
  "main": "./lib/index.js",
  "module": "./es/index.js",
  "scripts": {
    "build": "build-lib",
    "build:production": "build-lib",
    "build:watch": "build-lib --watch",
    "clean": "clean",
    "format": "yarn format:js",
    "format:js": "format-js --pattern './src/**/*.js'",
